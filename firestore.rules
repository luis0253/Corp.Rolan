rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /vehiculos/{vehicleId} {
      allow read, write: if true;
    }
    
    match /config/{document=**} {
      allow read, write: if true;
    }
    
    match /config/general {
      allow read, write: if true;
    }

    match /quote_history/{docId} {
      allow read, write: if true;
    }
  }
}